# ─── Server Configuration ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas Connection String ─────────────────────
# Replace with your actual MongoDB Atlas URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/campusmart
MONGODB_DB_NAME=campusmart

# ─── CORS — Deployed Frontend URL ────────────────────────
# Set this to your deployed frontend URL so the API accepts requests from it
# Example: https://campusmart.vercel.app or https://campusmart.netlify.app
FRONTEND_URL=http://localhost:5173
